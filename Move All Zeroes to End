Move All Zeroes to End



class Solution {
    void pushZerosToEnd(int[] arr) {
        // code here
        int j=0;
        for(int i=0;i<arr.length;i++){
            if(arr[i]!=0){
                int temp=arr[i];
                arr[j]=arr[i];
                arr[i]=temp;
                j++;
            }
        }
        for(;j<arr.length;j++){
            arr[j]=0;
        }
    }
}
