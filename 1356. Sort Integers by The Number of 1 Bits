1356. Sort Integers by The Number of 1 Bits
class Solution {
    public int[] sortByBits(int[] arr) {
        ArrayList<Integer>[] a = new ArrayList[500];
        for (int i = 0; i < 500; i++) {
            a[i] = new ArrayList<>();
        }
        int ans[]=new int[arr.length];
        for(int i:arr){
            int countBit=Integer.bitCount(i);
            a[countBit].add(i);
        }
        int j=0;
        for(int i=0;i<500;i++){

            if(!a[i].isEmpty()){
                int k=0;
                Collections.sort(a[i]);
                while(k<a[i].size()){
                    ans[j++]=a[i].get(k);
                    k++;
                }
            }
        }
        return ans;
    }
}
